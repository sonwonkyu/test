# ==========================================
# Freecart 환경 변수 템플릿 (Vite SPA)
# ==========================================
# 이 파일을 .env로 복사한 후 값을 입력하세요:
#   cp .env.example .env
# ==========================================

# ==========================================
# Supabase (필수)
# ==========================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ==========================================
# 사이트 정보
# ==========================================
VITE_SITE_URL=
VITE_SITE_NAME=

# ==========================================
# PG 결제 - 토스페이먼츠 (선택)
# ==========================================
VITE_TOSS_CLIENT_KEY=

# ==========================================
# Cloudflare (배포 시)
# ==========================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PROJECT_NAME=
